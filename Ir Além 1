/*
 * FARMTECH SOLUTIONS - ESP32 para ThingSpeak
 * Monitoramento ambiental com envio de dados para nuvem
 */

#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include "DHT.h"
#include <WiFi.h>
#include <HTTPClient.h>
#include <ArduinoJson.h> // 

const char* THINGSPEAK_API_KEY = "Y3EG7DJ1U84FNJDX";
const char* THINGSPEAK_URL = "http://api.thingspeak.com/update";

// LCDs: sensores (0x27) e status (0x3F)
LiquidCrystal_I2C lcd_sensores(0x27, 20, 4);
LiquidCrystal_I2C lcd_status(0x3F, 20, 4);

// Configuração do DHT22
#define DHTPIN 25
#define DHTTYPE DHT22
DHT dht(DHTPIN, DHTTYPE);

// Pino analógico do LDR
#define LDR_PIN 34

// WiFi (Wokwi ou ambiente real)
const char* ssid     = "Wokwi-GUEST";
const char* password = "";

// Variáveis globais de leitura
float temperatura  = 0.0;
float umidade      = 0.0;
int   luminosidade = 0;

// Controle de tempo (non-blocking com millis)
unsigned long ultimaLeitura = 0;
unsigned long ultimoEnvio   = 0;

const unsigned long INTERVALO_LEITURA = 2000;   // leitura dos sensores
const unsigned long INTERVALO_ENVIO   = 15000;  // limite ThingSpeak

void setup() {
  Serial.begin(115200);

  lcd_sensores.init(); lcd_sensores.backlight();
  lcd_status.init();   lcd_status.backlight();

  dht.begin();
  conectarWiFi();
}

void loop() {
  unsigned long agora = millis();

  // Leitura periódica dos sensores
  if (agora - ultimaLeitura >= INTERVALO_LEITURA) {
    ultimaLeitura = agora;
    lerSensores();
    atualizarLCD();
  }

  // Envio periódico para ThingSpeak
  if (agora - ultimoEnvio >= INTERVALO_ENVIO) {
    ultimoEnvio = agora;
    enviarParaThingSpeak();
  }

  delay(100); // pequena folga para estabilidade
}

void conectarWiFi() {
  WiFi.begin(ssid, password);

  int tentativas = 0;
  while (WiFi.status() != WL_CONNECTED && tentativas < 20) {
    delay(500);
    Serial.print(".");
    tentativas++;
  }

  if (WiFi.status() == WL_CONNECTED) {
    Serial.println("\n[WiFi] OK! IP: " + WiFi.localIP().toString());

    lcd_status.clear();
    lcd_status.setCursor(0,0); lcd_status.print("Wi-Fi: CONECTADO");
    lcd_status.setCursor(0,1); lcd_status.print("ThingSpeak: OK");
  }
}

void lerSensores() {
  float t = dht.readTemperature();
  float u = dht.readHumidity();

  // Atualiza apenas se leitura válida
  if (!isnan(t)) temperatura = t;
  if (!isnan(u)) umidade = u;

  int ldr = analogRead(LDR_PIN);

  // Converte ADC (0–4095) para porcentagem (invertido)
  luminosidade = map(ldr, 4095, 0, 0, 100);
  luminosidade = constrain(luminosidade, 0, 100);

  Serial.printf("[SENSOR] T:%.1fC U:%.1f%% L:%d%%\n",
                temperatura, umidade, luminosidade);
}

void atualizarLCD() {
  lcd_sensores.clear();

  lcd_sensores.setCursor(0,0);
  lcd_sensores.print("FARMTECH SOLUTIONS");

  lcd_sensores.setCursor(0,1);
  lcd_sensores.print("T:");
  lcd_sensores.print(temperatura,1);
  lcd_sensores.print("C");

  lcd_sensores.setCursor(0,2);
  lcd_sensores.print("U:");
  lcd_sensores.print(umidade,1);
  lcd_sensores.print("%");

  lcd_sensores.setCursor(0,3);
  lcd_sensores.print("L:");
  lcd_sensores.print(luminosidade);
  lcd_sensores.print("%");
}

void enviarParaThingSpeak() {
  // Evita envio sem conexão
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;

  // Monta URL com parâmetros
  String url = THINGSPEAK_URL;
  url += "?api_key=" + String(THINGSPEAK_API_KEY);
  url += "&field1=" + String(temperatura);
  url += "&field2=" + String(umidade);
  url += "&field3=" + String(luminosidade);

  http.begin(url);

  int code = http.GET(); // requisição HTTP GET

  Serial.printf("[ThingSpeak] HTTP: %d\n", code);

  http.end(); // libera recursos
}
